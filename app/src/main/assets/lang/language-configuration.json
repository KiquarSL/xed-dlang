{
	"comments": {
		"lineComment": "//",
		"blockComment": [
			"/*",
			"*/"
		]
	},
	"brackets": [
		["{", "}"],
		["[", "]"],
		["(", ")"]
	],
	"autoClosingPairs": [
		{
			"open": "[",
			"close": "]"
		},
		{
			"open": "{",
			"close": "}"
		},
		{
			"open": "(",
			"close": ")"
		},
		{
			"open": "'",
			"close": "'",
			"notIn": ["string", "comment"]
		},
		{
			"open": "\"",
			"close": "\"",
			"notIn": ["string"]
		},
		{
			"open": "`",
			"close": "`",
			"notIn": ["string", "comment"]
		},
		{
			"open": "/*",
			"close": "*/",
			"notIn": ["string", "comment"]
		},
		{
			"open": "/+",
			"close": "+/",
			"notIn": ["string", "comment"]
		}
	],
	"surroundingPairs": [
		["{", "}"],
		["[", "]"],
		["(", ")"],
		["\"", "\""],
		["'", "'"],
		["`", "`"],
		["<", ">"]
	],
	"wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
	"folding": {
		"markers": {
			"start": "^\\s*//\\s*#region\\b|^\\s*/\\*\\s*#region\\b|^\\s*\\+\\s*#region\\b",
			"end": "^\\s*//\\s*#endregion\\b|^\\s*/\\*\\s*#endregion\\b|^\\s*\\+\\s*#endregion\\b"
		}
	},
	"indentationRules": {
		"decreaseIndentPattern": {
			"pattern": "^\\s*[\\}\\]\\)].*$"
		},
		"increaseIndentPattern": {
			"pattern": "^.*(\\{[^}]*|\\([^)]*|\\[[^\\]]*)$"
		}
	},
	"onEnterRules": [
		{
			"beforeText": "^\\s*//|\\s//\\s",
			"afterText": "^(?!\\s*$)",
			"action": {
				"indent": "none",
				"appendText": "// "
			}
		},
		{
			"beforeText": "^\\s*/\\*",
			"afterText": "^(?!\\s*$)",
			"action": {
				"indent": "none",
				"appendText": " * "
			}
		},
		{
			"beforeText": "^\\s*/\\+",
			"afterText": "^(?!\\s*$)",
			"action": {
				"indent": "none",
				"appendText": " + "
			}
		}
	]
}